.define DE 7
.define RDATA 6
.define RCLK 5
.define COLLAT 4
.define DOTCLK 3
.define SDATA 2
.define SDATAEX 1
.define FRAME_START_IRQ 5

.program dmd_reader_de_x16

    set x, 31             ; load 31, 5 bits is max allowed (0b11111)
    in x, 5               ; shift in 5 bits, isr is 31 now
    set x, 1              ; load 1, 1 bit
    in x, 1               ; shift in 1 bit, isr is 63 now
    mov osr, isr          ; copy 63 to osr
    mov isr, null                 ; clear ISR and reset shift counter

    wait irq FRAME_START_IRQ

.wrap_target

    mov x, osr                    ; copy 63 to x

lsb_msb_check:
    jmp pin dotloop_lsb_msb  [31] ; if DOTCLK goes high early, it means we will have LSB + MSB
    jmp x-- lsb_msb_check    [31] ; loop for ~30 µs
    in null 32                    ; padding for row with only MSB
    in null 32                    ; padding for row with only MSB
    set x, 31                   
    jmp y-- dotloop
dotloop_lsb_msb:
    mov x, osr
dotloop:
    wait 1 gpio DOTCLK               ; rising edge
    in pins 2                        ; read value of px 1 and 2 as they're sampled on the same DOTCLK edge
    wait 0 gpio DOTCLK               ; falling edge
    jmp x-- dotloop
.wrap

; Frame detection program runs in parallel to the reader program and signals the start of a new frame using an IRQ.
.program dmd_framedetect_de_x16
.wrap_target

; Data East 128x16 frame detection
; When RCLK goes low, we check if RDATA goes high about ~8 µs later. If this is true then we found the start.

wait_low:
    wait 0 gpio RCLK       ; Wait for RCLK to go low
    set x, 31              ; Use x as storage for 32 iterations

delay_loop:
    nop[31]                
    jmp x-- delay_loop [31]     ; Decrement x and repeat until zero

    ; After ~15 µs, check if RDATA is high
    jmp pin, frame_start   ; If pin RDATA is high we found the start of a frame
    jmp wait_low           ; If RDATA is low, go back to the beginning

frame_start:
    irq FRAME_START_IRQ
    wait 0 gpio RDATA      ; Wait again for RDATA to go low before restarting cycle   /// !! could be removed
.wrap


.wrap_target
wait 0 de
wait 1 de
jmp pin, frame_start
.wrap

frame_start:
    irq FRAME_START_IRQ