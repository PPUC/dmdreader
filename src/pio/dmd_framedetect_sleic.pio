.define DE 7
.define RDATA 6
.define RCLK 5
.define COLLAT 4
.define DOTCLK 3
.define SDATA 2
.define FRAME_START_IRQ 5

; Frame detection program runs in parallel to the reader program and signals the start of a new frame using an IRQ.
.program dmd_framedetect_sleic

    set x, 3            ; x = 3
    in x, 2             ; shift in 2 bits, isr = 3
    in null, 11         ; shift left by 11 bits = 6144

.wrap_target

wait_low:
    mov x, isr          ; set x to 6144
    wait 0 gpio DE      ; Wait for DE to go low

delay_loop:
    jmp pin, wait_low   ; If pin went high early → back to wait_low
    jmp x-- delay_loop  ; Decrement x and repeat until zero

    ; If after ~100 µs still low → frame start found
    wait 1 gpio RDATA
    irq FRAME_START_IRQ
.wrap