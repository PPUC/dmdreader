.define DE 7
.define RDATA 6
.define RCLK 5
.define COLLAT 4
.define DOTCLK 3
.define SDATA 2
.define FRAME_START_IRQ 5

.program dmd_framedetect_alving
.wrap_target
    mov x, osr            ; set x to 127, we need to skip 128 COLLAT edges
    wait 1 gpio RDATA

collat_loop:
    wait 0 gpio COLLAT
    wait 1 gpio COLLAT
    jmp x--collat_loop

    irq FRAME_START_IRQ
.wrap